{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
